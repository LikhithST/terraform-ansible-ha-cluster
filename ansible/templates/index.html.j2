<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cluster Status</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; padding-top: 50px; }
        .server-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            transition: transform 0.2s;
        }
        .server-card:hover { transform: translateY(-5px); }
        .status-indicator {
            height: 15px; width: 15px; background-color: #28a745;
            border-radius: 50%; display: inline-block; margin-right: 10px;
        }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">DevOps Cluster Node</h1>
                <p class="lead text-muted">Traffic balanced via Nginx Load Balancer</p>
            </div>

            <div class="card server-card p-4">
                <div class="card-body text-center">
                    <h2 class="card-title mb-3">
                        <span class="status-indicator"></span>
                        {{ ansible_hostname }}
                    </h2>
                    <hr>
                    <div class="row text-start mt-4">
                        <div class="col-6">
                            <p><strong>IP Address:</strong></p>
                            <p><strong>OS Distribution:</strong></p>
                            <p><strong>Total Memory:</strong></p>
                            <p><strong>Managed By:</strong></p>
                        </div>
                        <div class="col-6 text-end">
                            <p class="text-primary font-monospace">{{ ansible_default_ipv4.address }}</p>
                            <p>{{ ansible_distribution }} {{ ansible_distribution_version }}</p>
                            <p>{{ ansible_memtotal_mb }} MB</p>
                            <p><span class="badge bg-danger">Ansible Automation</span></p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 text-muted mt-3">
                    <small>Last Configured: {{ ansible_date_time.iso8601 }}</small>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>